# Static preview defaults
# If VITE_API_BASE_URL is empty, the app uses local demo auth.
VITE_AUTH_MODE=local
VITE_API_BASE_URL=
VITE_ENABLE_DEMO_AUTH=true
VITE_ENABLE_PUBLIC_REGISTRATION=false
VITE_AUTH_SESSION_MINUTES=60

# Demo/static credentials. For a real production store, switch VITE_AUTH_MODE=api and use a backend.
VITE_DEMO_ADMIN_EMAIL=admin@sila.local
VITE_DEMO_ADMIN_PASSWORD=Sila@12345
