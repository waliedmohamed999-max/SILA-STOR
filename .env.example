# Production defaults
VITE_AUTH_MODE=api
VITE_API_BASE_URL=https://api.example.com
VITE_ENABLE_DEMO_AUTH=false
VITE_ENABLE_PUBLIC_REGISTRATION=false
VITE_AUTH_SESSION_MINUTES=60

# Optional local-only demo credentials. Do not use production passwords here.
# Demo auth only runs in Vite dev mode unless you explicitly override it.
VITE_DEMO_ADMIN_EMAIL=
VITE_DEMO_ADMIN_PASSWORD=
